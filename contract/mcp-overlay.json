        "mode": "async",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "createWorld": {
