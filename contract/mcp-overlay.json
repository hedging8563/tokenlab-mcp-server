{
  "schema_version": 1,
  "openapi_url": "https://docs.tokenlab.sh/openapi.json",
  "default_profile": "core",
  "profiles": {
    "catalog": {
      "operations": [
        "listModels",
        "getModel",
        "getModelPricing",
        "getPricing"
      ]
    },
    "core": {
      "operations": [
        "listModels",
        "getModel",
        "getModelPricing",
        "getPricing",
        "createChatCompletion",
        "createResponse",
        "createAnthropicMessage",
        "geminiGenerateContent",
        "createEmbedding",
        "createMultimodalEmbedding",
        "rerankDocuments",
        "createTranslation",
        "createImage",
        "editImage",
        "createVideo",
        "createMusic",
        "create3D",
        "getAsyncTask",
        "cancelAsyncTask",
        "createSpeech",
        "createTranscription",
        "createAudioTranslation",
        "uploadFile",
        "listFiles",
        "retrieveFile",
        "retrieveFileContent",
        "deleteFile"
      ]
    },
    "full": {
      "include_tags": [
        "Chat",
        "Embeddings",
        "Images",
        "Audio",
        "Video",
        "Tasks",
        "Models",
        "Anthropic",
        "Gemini",
        "Files",
        "Batches",
        "Text",
        "Worlds",
        "Seedance Volc Compatible"
      ],
      "exclude_operations": [
        "geminiStreamGenerateContent",
        "connectRealtime"
      ]
    }
  },
  "public_contract": {
    "landing_url": "https://tokenlab.sh/mcp",
    "docs_url": "https://docs.tokenlab.sh/integrations/tokenlab-mcp-server",
    "recommended_client_name": "tokenlab",
    "composite_tools": [
      {
        "name": "compare_models",
        "profiles": ["catalog", "core", "full"],
        "auth": "optional",
        "annotations": {
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": true
        }
      },
      {
        "name": "get_api_overview",
        "profiles": ["catalog", "core", "full"],
        "auth": "optional",
        "annotations": {
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": true
        }
      }
    ],
    "core_tool_layers": [
      {
        "id": "discover",
        "authentication": "none",
        "tool_rows": [
          ["list_models", "get_model", "get_pricing"],
          ["get_model_pricing", "compare_models", "get_api_overview"]
        ]
      },
      {
        "id": "create",
        "authentication": "api_key",
        "tool_rows": [
          ["create_chat_completion", "create_response", "create_anthropic_message", "create_gemini_content"],
          ["create_image", "create_image_file", "edit_image", "edit_image_file"],
          ["create_video", "create_music", "create_3d_model", "create_speech", "transcribe_audio", "translate_audio"]
        ]
      },
      {
        "id": "operate",
        "authentication": "api_key",
        "tool_rows": [
          ["upload_file", "list_files", "retrieve_file"],
          ["retrieve_file_content", "delete_file", "get_task_status", "cancel_task"],
          ["create_embedding", "create_multimodal_embedding", "rerank_documents", "translate_text"]
        ]
      }
    ],
    "resources": [
      {
        "name": "tokenlab-api-overview",
        "title": "TokenLab API Overview",
        "uri": "tokenlab://api/overview",
        "mime_type": "text/plain",
        "freshness": "live"
      },
      {
        "name": "tokenlab-openapi-contract",
        "title": "TokenLab OpenAPI Contract",
        "uri": "tokenlab://contract/openapi",
        "mime_type": "application/json",
        "freshness": "package_snapshot"
      },
      {
        "name": "tokenlab-mcp-public-contract",
        "title": "TokenLab MCP Public Contract",
        "uri": "tokenlab://contract/mcp",
        "mime_type": "application/json",
        "freshness": "package_snapshot"
      }
    ],
    "prompts": [
      {
        "name": "choose_tokenlab_model",
        "title": "Choose a TokenLab Model"
      },
      {
        "name": "build_tokenlab_request",
        "title": "Build a TokenLab Request"
      }
    ]
  },
  "public_auth_operations": [
    "listModels",
    "getModel",
    "getModelPricing",
    "getPricing"
  ],
  "operation_overrides": {
    "listModels": {
      "default_arguments": {
        "view": "compact"
      },
      "input_property_overrides": {
        "view": {
          "description": "Compact model-selection output is the MCP default. Set view to full only when the complete OpenAI-compatible list shape is required."
        }
      }
    },
    "cancelAnthropicMessageBatch": {
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": true,
        "openWorldHint": true
      }
    },
    "cancelBatch": {
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": true,
        "openWorldHint": true
      }
    },
    "createAnthropicMessage": {
      "tool_name": "create_anthropic_message",
      "input_property_overrides": {
        "stream": {
          "const": false,
          "description": "MCP tool calls return one final result; omit stream or set it to false."
        }
      }
    },
    "geminiGenerateContent": {
      "tool_name": "create_gemini_content",
      "omit_arguments": ["key"]
    },
    "createChatCompletion": {
      "input_property_overrides": {
        "stream": {
          "const": false,
          "description": "MCP tool calls return one final result; omit stream or set it to false."
        }
      }
    },
    "createResponse": {
      "input_property_overrides": {
        "stream": {
          "const": false,
          "description": "MCP tool calls return one final result; omit stream or set it to false."
        }
      }
    },
    "getAsyncTask": {
      "tool_name": "get_task_status",
      "task": {
        "mode": "status",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "cancelAsyncTask": {
      "tool_name": "cancel_task",
      "task": {
        "mode": "status",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "createTranslation": {
      "tool_name": "translate_text"
    },
    "createAudioTranslation": {
      "tool_name": "translate_audio"
    },
    "createTranscription": {
      "tool_name": "transcribe_audio"
    },
    "createImage": {
      "all_content_types": true,
      "tool_names_by_content_type": {
        "application/json": "create_image",
        "multipart/form-data": "create_image_file"
      },
      "input_property_overrides": {
        "stream": {
          "const": false,
          "description": "Image streaming is not exposed through MCP tool calls; omit stream or set it to false."
        }
      },
      "task": {
        "mode": "hybrid",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "editImage": {
      "all_content_types": true,
      "tool_names_by_content_type": {
        "application/json": "edit_image",
        "multipart/form-data": "edit_image_file"
      },
      "input_property_overrides": {
        "stream": {
          "const": false,
          "description": "Image streaming is not exposed through MCP tool calls; omit stream or set it to false."
        }
      },
      "task": {
        "mode": "hybrid",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "createVideo": {
      "task": {
        "mode": "async",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "createMusic": {
      "task": {
        "mode": "async",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "create3D": {
      "tool_name": "create_3d_model",
      "task": {
        "mode": "async",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "createWorld": {
      "task": {
        "mode": "async",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    },
    "getWorldStatus": {
      "task": {
        "mode": "status",
        "id_fields": ["task_id", "id"],
        "status_field": "status",
        "poll_url_field": "poll_url",
        "terminal_statuses": ["completed", "succeeded", "failed", "cancelled", "canceled", "expired"]
      }
    }
  }
}
